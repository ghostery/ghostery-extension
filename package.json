{
  "name": "ghostery-extension",
  "private": true,
  "version": "10.5.49",
  "type": "module",
  "scripts": {
    "build": "node scripts/build.js",
    "start": "npm run build -- --watch",
    "start:update": "./scripts/update.sh",
    "debug": "npm run build -- --watch --debug",
    "lint": "npm run lint:src && npm run lint:build",
    "lint:src": "eslint",
    "lint:build": "npm run build firefox -- --silent && web-ext lint",
    "test": "npm run test:unit && npm run wdio && npm run wdio:update",
    "test:unit": "node --import ./tests/unit/setup/register-import.js --test",
    "wdio": "wdio tests/e2e/wdio.conf.js",
    "wdio:update": "wdio tests/e2e/wdio.update.conf.js",
    "wdio:page": "node tests/e2e/page/server.js",
    "locales:setup": "cp -f ./src/messages.json ./src/_locales/en/messages.json",
    "locales.src": "hybrids extract -c --format=chrome.i18n ./src ./src/_locales/en/messages.json",
    "locales": "npm run locales:setup && npm run locales.src",
    "xcode-export-locales": "rm -rf ./xcode/en.xcloc && xcodebuild -exportLocalizations -project ./xcode/Ghostery.xcodeproj -localizationPath ./xcode",
    "release": "./scripts/release.sh",
    "package": "./scripts/package.sh",
    "app-store-connect": "node scripts/app-store-connect.js"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/chrome": "^0.2.0",
    "@wdio/browser-runner": "^9.29.0",
    "@wdio/cli": "^9.29.0",
    "@wdio/globals": "^9.27.0",
    "@wdio/mocha-framework": "^9.27.0",
    "@wdio/spec-reporter": "^9.29.0",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "globals": "^17.7.0",
    "license-report": "^6.8.5",
    "prettier": "^3.8.4",
    "vite": "^8.1.0",
    "web-ext": "^10.4.0"
  },
  "dependencies": {
    "@duckduckgo/autoconsent": "^15.1.0",
    "@ghostery/adblocker": "^2.18.0",
    "@ghostery/adblocker-content": "^2.17.0",
    "@ghostery/adblocker-extended-selectors": "^2.17.0",
    "@ghostery/adblocker-webextension": "^2.18.0",
    "@ghostery/config": "^0.0.15",
    "@ghostery/scriptlets": "github:ghostery/scriptlets",
    "@ghostery/urlfilter2dnr": "^2.0.4",
    "@github/relative-time-element": "^5.2.0",
    "@sentry/browser": "^10.60.0",
    "@whotracksme/reporting": "^11.0.0",
    "apexsankey": "github:ghostery/apexsankey",
    "bowser": "^2.14.1",
    "csv-stringify": "^6.8.0",
    "hybrids": "^9.1.22",
    "idb": "^8.0.3",
    "lottie-web": "^5.13.0",
    "minixxh": "^0.3.1",
    "plotly.js-basic-dist": "^3.6.0",
    "tldts-experimental": "^7.4.4"
  },
  "dataDependencies": {
    "redirect-resources": "737ccfe7d0c3dbe4c429986aeb9793bd6e559a875d52f1d643b3b87cbb6a945e",
    "wtm-bloomfilter": "2026-06-22",
    "wtm-stats": "f3a96d53d9960def8cd112051904e9132a747685"
  },
  "engineStrict": true,
  "engines": {
    "npm": ">=11.6.3"
  },
  "webExt": {
    "sourceDir": "./dist/"
  },
  "author": {
    "name": "Ghostery GmbH",
    "email": "info@ghostery.com",
    "url": "https://www.ghostery.com"
  },
  "license": "GPL-3.0"
}
