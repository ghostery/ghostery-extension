{
  "name": "ghostery-extension",
  "private": true,
  "version": "10.5.34",
  "type": "module",
  "scripts": {
    "build": "node scripts/build.js",
    "start": "npm run build -- --watch",
    "start:update": "./scripts/update.sh",
    "debug": "npm run build -- --watch --debug",
    "lint": "npm run lint:src && npm run lint:build",
    "lint:src": "eslint",
    "lint:build": "npm run build firefox -- --silent && addons-linter dist",
    "test": "npm run test:unit && npm run wdio && npm run wdio:update",
    "test:unit": "node --import ./tests/unit/setup/register-import.js --test",
    "wdio": "wdio tests/e2e/wdio.conf.js",
    "wdio:update": "wdio tests/e2e/wdio.update.conf.js",
    "wdio:page": "node tests/e2e/page/server.js",
    "locales:setup": "cp -f ./src/messages.json ./src/_locales/en/messages.json",
    "locales.src": "hybrids extract -c --format=chrome.i18n ./src ./src/_locales/en/messages.json",
    "locales": "npm run locales:setup && npm run locales.src",
    "xcode-export-locales": "rm -rf ./xcode/en.xcloc && xcodebuild -exportLocalizations -project ./xcode/Ghostery.xcodeproj -localizationPath ./xcode",
    "release": "./scripts/release.sh",
    "package": "./scripts/package.sh"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/chrome": "^0.1.37",
    "@wdio/browser-runner": "^9.26.1",
    "@wdio/cli": "^9.26.1",
    "@wdio/globals": "^9.12.7",
    "@wdio/mocha-framework": "^9.12.6",
    "@wdio/spec-reporter": "^9.26.1",
    "addons-linter": "^10.0.0",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.4.0",
    "license-report": "^6.8.2",
    "prettier": "^3.8.1",
    "vite": "^7.3.1",
    "web-ext": "^9.4.0"
  },
  "dependencies": {
    "@duckduckgo/autoconsent": "^14.59.0",
    "@ghostery/adblocker": "^2.14.1",
    "@ghostery/adblocker-content": "^2.13.3",
    "@ghostery/adblocker-extended-selectors": "^2.13.3",
    "@ghostery/adblocker-webextension": "^2.14.1",
    "@ghostery/config": "^0.0.10",
    "@ghostery/scriptlets": "github:ghostery/scriptlets",
    "@ghostery/urlfilter2dnr": "^1.7.2",
    "@github/relative-time-element": "^5.0.0",
    "@sentry/browser": "^10.43.0",
    "@whotracksme/reporting": "^7.12.1",
    "apexsankey": "github:ghostery/apexsankey",
    "bowser": "^2.14.1",
    "csv-stringify": "^6.6.0",
    "hybrids": "^9.1.22",
    "idb": "^8.0.2",
    "lottie-web": "^5.13.0",
    "plotly.js-basic-dist": "^3.4.0",
    "tldts-experimental": "^7.0.25"
  },
  "dataDependencies": {
    "redirect-resources": "e1b016fd6a5dd4d590e2149af281751925cb245e3de8377004b43471798d8760",
    "wtm-bloomfilter": "2026-03-09",
    "wtm-stats": "918d53423e8afc860fea07b597d71e0b9a9f4da9"
  },
  "engineStrict": true,
  "engines": {
    "npm": ">=11.6.3"
  },
  "webExt": {
    "sourceDir": "./dist/"
  },
  "author": {
    "name": "Ghostery GmbH",
    "email": "info@ghostery.com",
    "url": "https://www.ghostery.com"
  },
  "license": "GPL-3.0"
}
